    "docx": "^9.6.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "mammoth": "^1.12.0",
    "mongoose": "^9.3.1",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1"
  }
}
